#!/usr/bin/env bash
# ssm-connect — Start an SSM session to an EC2 instance
# Usage:
#   ssm-connect                  # interactive: list instances & pick one
#   ssm-connect i-0abc123def     # connect by instance ID
#   ssm-connect my-server        # connect by Name tag (partial match)
#
# The session runs as ubuntu user with a login shell by default.
# Override the OS user with:  SSM_USER=ec2-user ssm-connect

set -euo pipefail

# ── Colours ──────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

err()  { echo -e "${RED}✖ $*${RESET}" >&2; }
info() { echo -e "${CYAN}ℹ $*${RESET}"; }
ok()   { echo -e "${GREEN}✔ $*${RESET}"; }

# ── Config ───────────────────────────────────────────────────
SSM_USER="${SSM_USER:-ubuntu}"

# ── Helpers ──────────────────────────────────────────────────
require_cmd() {
  command -v "$1" &>/dev/null || { err "Required command not found: $1"; exit 1; }
}

fetch_instances() {
  aws ec2 describe-instances \
    --query "Reservations[].Instances[?State.Name=='running'].{ID:InstanceId,Name:Tags[?Key=='Name']|[0].Value,PrivateIP:PrivateIpAddress,PublicIP:PublicIpAddress}" \
    --output json | jq -c '.[][] '
}

start_ssm() {
  local instance_id="$1"
  local name="${2:-}"
  if [[ -n "$name" ]]; then
    ok "Connecting to ${BOLD}${name}${RESET}${GREEN} (${instance_id})${RESET} as ${BOLD}${SSM_USER}${RESET}"
  else
    ok "Connecting to ${BOLD}${instance_id}${RESET} as ${BOLD}${SSM_USER}${RESET}"
  fi
  echo ""
  aws ssm start-session --target "$instance_id" \
    --document-name AWS-StartInteractiveCommand \
    --parameters "command=[\"sudo -i -u ${SSM_USER} bash --login -c 'run-parts /etc/update-motd.d/; stty -ixon; exec bash'\"]"
}

# ── Pre-checks ───────────────────────────────────────────────
require_cmd aws
require_cmd jq

# ── Direct mode: argument provided ──────────────────────────
if [[ $# -ge 1 ]]; then
  target="$1"

  # If it looks like an instance ID, use it directly
  if [[ "$target" =~ ^i-[0-9a-f]+$ ]]; then
    # Resolve name for display
    name=$(aws ec2 describe-instances --instance-ids "$target" \
      --query "Reservations[].Instances[].Tags[?Key=='Name']|[0][0].Value" \
      --output text 2>/dev/null || true)
    [[ "$name" == "None" ]] && name=""
    start_ssm "$target" "$name"
    exit 0
  fi

  # Otherwise treat as a Name tag search (case-insensitive partial match)
  mapfile -t matches < <(
    aws ec2 describe-instances \
      --query "Reservations[].Instances[?State.Name=='running'].{ID:InstanceId,Name:Tags[?Key=='Name']|[0].Value}" \
      --output json | jq -r --arg pat "$target" \
        '.[] | select(.Name != null) | select(.Name | ascii_downcase | contains($pat | ascii_downcase)) | "\(.ID)\t\(.Name)"'
  )

  if [[ ${#matches[@]} -eq 0 ]]; then
    err "No running instance found matching '${target}'"
    exit 1
  elif [[ ${#matches[@]} -eq 1 ]]; then
    IFS=$'\t' read -r id name <<< "${matches[0]}"
    start_ssm "$id" "$name"
    exit 0
  else
    info "Multiple instances match '${target}':"
    for i in "${!matches[@]}"; do
      IFS=$'\t' read -r id name <<< "${matches[$i]}"
      printf "  ${BOLD}%d)${RESET} %-22s %s\n" "$((i+1))" "$id" "$name"
    done
    echo ""
    read -rp "Select [1-${#matches[@]}]: " choice
    if [[ ! "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#matches[@]} )); then
      err "Invalid selection"; exit 1
    fi
    IFS=$'\t' read -r id name <<< "${matches[$((choice-1))]}"
    start_ssm "$id" "$name"
    exit 0
  fi
fi

# ── Interactive mode: no arguments ──────────────────────────
info "Fetching running instances…"
mapfile -t instances < <(fetch_instances)

if [[ ${#instances[@]} -eq 0 ]]; then
  err "No running instances found"
  exit 1
fi

echo ""
printf "  ${BOLD}%-4s %-22s %-16s %-16s %s${RESET}\n" "#" "Instance ID" "Private IP" "Public IP" "Name"
printf "  %-4s %-22s %-16s %-16s %s\n" "----" "----------------------" "----------------" "----------------" "----"

for i in "${!instances[@]}"; do
  id=$(echo "${instances[$i]}" | jq -r '.ID')
  name=$(echo "${instances[$i]}" | jq -r '.Name // "-"')
  priv=$(echo "${instances[$i]}" | jq -r '.PrivateIP // "-"')
  pub=$(echo "${instances[$i]}" | jq -r '.PublicIP // "-"')
  printf "  ${BOLD}%-4s${RESET} %-22s %-16s %-16s %s\n" "$((i+1))" "$id" "$priv" "$pub" "$name"
done

echo ""
read -rp "Select instance [1-${#instances[@]}]: " choice

if [[ ! "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#instances[@]} )); then
  err "Invalid selection"
  exit 1
fi

selected="${instances[$((choice-1))]}"
id=$(echo "$selected" | jq -r '.ID')
name=$(echo "$selected" | jq -r '.Name // ""')

start_ssm "$id" "$name"
