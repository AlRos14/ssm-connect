#!/usr/bin/env bash
# ssm-connect — Open a shell or port-forward to an EC2 instance via SSM.
# No SSH, no port 22 — works in private subnets and behind NAT.

set -euo pipefail

VERSION="0.1.1"

# ── Colours ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

err()  { echo -e "${RED}✖ $*${RESET}" >&2; }
info() { echo -e "${CYAN}ℹ $*${RESET}" >&2; }
ok()   { echo -e "${GREEN}✔ $*${RESET}" >&2; }
warn() { echo -e "${YELLOW}⚠ $*${RESET}" >&2; }

# ── Defaults ─────────────────────────────────────────────────────────────────
SSM_USER="${SSM_USER:-ubuntu}"
OPT_PROFILE=""
OPT_REGION=""
OPT_FORWARD=""
OPT_REASON=""
POSITIONAL=()

# ── Helpers ───────────────────────────────────────────────────────────────────
require_cmd() {
  command -v "$1" &>/dev/null || { err "Required command not found: $1"; exit 1; }
}

# Wrapper that injects --profile / --region into every aws call when set
aws_cmd() {
  local -a cmd=(aws)
  [[ -n "$OPT_PROFILE" ]] && cmd+=(--profile "$OPT_PROFILE")
  [[ -n "$OPT_REGION"  ]] && cmd+=(--region  "$OPT_REGION")
  "${cmd[@]}" "$@"
}

usage() {
  cat >&2 <<EOF
${BOLD}ssm-connect${RESET} v${VERSION}  Open a shell or port-forward to an EC2 instance via SSM.
No SSH, no port 22 — works in private subnets and behind NAT.

${BOLD}Usage:${RESET}
  ssm-connect [options] [target]                   open an interactive shell
  ssm-connect [options] -L local:remote_port       forward to port on instance
  ssm-connect [options] -L local:host:remote_port  forward via instance to host:port

${BOLD}Target:${RESET}
  (none)          interactive picker  — lists all running instances
  i-0abc123...    instance ID         — exact match
  my-server       Name tag            — partial, case-insensitive

${BOLD}Options:${RESET}
  -p, --profile NAME     AWS CLI profile
  -r, --region  REGION   AWS region
  -u, --user    USER     OS user on the instance  [default: ubuntu | env: \$SSM_USER]
  -L, --forward SPEC     port-forward spec (see Usage above)
      --reason  TEXT     reason string attached to the session (CloudTrail audit)
  -V, --version          print version and exit
  -h, --help             print this help and exit

${BOLD}Examples:${RESET}
  ssm-connect                                      interactive picker
  ssm-connect prod-api                             connect to instance named prod-api
  ssm-connect -p prod -r eu-west-1 web             specific profile and region
  ssm-connect -L 5432:5432 db-server               forward local 5432 → instance:5432
  ssm-connect -L 5432:rds.internal:5432 bastion    tunnel to RDS via bastion
  ssm-connect --reason "incident-2026-03" api      tag session for audit trail
  SSM_USER=ec2-user ssm-connect my-server          connect as ec2-user
EOF
}

# ── Argument parsing ──────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--profile) OPT_PROFILE="$2"; shift 2 ;;
    -r|--region)  OPT_REGION="$2";  shift 2 ;;
    -u|--user)    SSM_USER="$2";    shift 2 ;;
    -L|--forward) OPT_FORWARD="$2"; shift 2 ;;
    --reason)     OPT_REASON="$2";  shift 2 ;;
    -V|--version) echo "ssm-connect $VERSION"; exit 0 ;;
    -h|--help)    usage; exit 0 ;;
    --)           shift; POSITIONAL+=("$@"); break ;;
    -*)           err "Unknown option: $1"; echo "" >&2; usage; exit 1 ;;
    *)            POSITIONAL+=("$1"); shift ;;
  esac
done

# ── Pre-checks ────────────────────────────────────────────────────────────────
require_cmd aws
require_cmd jq

# ── Input validation ──────────────────────────────────────────────────────────
validate_user() {
  [[ "$1" =~ ^[a-zA-Z0-9._-]+$ ]] || {
    err "Invalid user '${1}': only alphanumeric, dot, dash and underscore are allowed"
    exit 1
  }
}

validate_port() {
  [[ "$1" =~ ^[0-9]+$ ]] && (( $1 >= 1 && $1 <= 65535 )) || {
    err "Invalid port '${1}': must be an integer between 1 and 65535"
    exit 1
  }
}

validate_host() {
  # Reject anything that could escape the JSON string (quotes, backslashes, spaces)
  [[ "$1" =~ ^[a-zA-Z0-9._-]+$ ]] || {
    err "Invalid host '${1}': only alphanumeric, dot, dash and underscore are allowed"
    exit 1
  }
}

validate_user "$SSM_USER"

# ── Instance resolution ───────────────────────────────────────────────────────
RESOLVED_ID=""
RESOLVED_NAME=""

resolve_by_id() {
  local target="$1" name
  name=$(aws_cmd ec2 describe-instances --instance-ids "$target" \
    --query "Reservations[].Instances[].Tags[?Key=='Name']|[0][0].Value" \
    --output text 2>/dev/null || true)
  [[ "$name" == "None" ]] && name=""
  RESOLVED_ID="$target"
  RESOLVED_NAME="$name"
}

resolve_by_name() {
  local target="$1"
  local -a matches
  mapfile -t matches < <(
    aws_cmd ec2 describe-instances \
      --query "Reservations[].Instances[?State.Name=='running'].{ID:InstanceId,Name:Tags[?Key=='Name']|[0].Value}" \
      --output json | jq -r --arg pat "$target" \
        '.[] | select(.Name != null) | select(.Name | ascii_downcase | contains($pat | ascii_downcase)) | "\(.ID)\t\(.Name)"'
  )

  if [[ ${#matches[@]} -eq 0 ]]; then
    err "No running instance found matching '${target}'"
    exit 1
  elif [[ ${#matches[@]} -eq 1 ]]; then
    IFS=$'\t' read -r RESOLVED_ID RESOLVED_NAME <<< "${matches[0]}"
  else
    info "Multiple instances match '${target}':"
    local i
    for i in "${!matches[@]}"; do
      local mid mname
      IFS=$'\t' read -r mid mname <<< "${matches[$i]}"
      printf "  ${BOLD}%d)${RESET} %-22s %s\n" "$((i+1))" "$mid" "$mname" >&2
    done
    echo "" >&2
    local choice
    read -rp "Select [1-${#matches[@]}]: " choice
    if [[ ! "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#matches[@]} )); then
      err "Invalid selection"; exit 1
    fi
    IFS=$'\t' read -r RESOLVED_ID RESOLVED_NAME <<< "${matches[$((choice-1))]}"
  fi
}

resolve_interactive() {
  info "Fetching running instances…"
  local -a instances
  mapfile -t instances < <(
    aws_cmd ec2 describe-instances \
      --query "Reservations[].Instances[?State.Name=='running'].{ID:InstanceId,Name:Tags[?Key=='Name']|[0].Value,PrivateIP:PrivateIpAddress,PublicIP:PublicIpAddress}" \
      --output json | jq -c '.[][]'
  )

  if [[ ${#instances[@]} -eq 0 ]]; then
    err "No running instances found"
    exit 1
  fi

  if command -v fzf &>/dev/null; then
    local -a lines=()
    local inst id name priv pub
    for inst in "${instances[@]}"; do
      id=$(echo "$inst"   | jq -r '.ID')
      name=$(echo "$inst" | jq -r '.Name // "-"')
      priv=$(echo "$inst" | jq -r '.PrivateIP // "-"')
      pub=$(echo "$inst"  | jq -r '.PublicIP // "-"')
      lines+=("$(printf "%-22s %-16s %-16s %s" "$id" "$priv" "$pub" "$name")")
    done
    local header selected
    header=$(printf "%-22s %-16s %-16s %s" "Instance ID" "Private IP" "Public IP" "Name")
    selected=$(printf '%s\n' "${lines[@]}" | \
      fzf --header="$header" --layout=reverse --prompt="Instance> ") || {
      err "No instance selected"; exit 1
    }
    RESOLVED_ID=$(awk 'NR==1 {print $1}' <<< "$selected")
    [[ -n "$RESOLVED_ID" ]] || { err "Failed to parse selected instance ID"; exit 1; }
    for inst in "${instances[@]}"; do
      local inst_id
      inst_id=$(echo "$inst" | jq -r '.ID')
      if [[ "$inst_id" == "$RESOLVED_ID" ]]; then
        RESOLVED_NAME=$(echo "$inst" | jq -r '.Name // ""')
        break
      fi
    done
  else
    echo "" >&2
    printf "  ${BOLD}%-4s %-22s %-16s %-16s %s${RESET}\n" \
      "#" "Instance ID" "Private IP" "Public IP" "Name" >&2
    printf "  %-4s %-22s %-16s %-16s %s\n" \
      "----" "----------------------" "----------------" "----------------" "----" >&2
    local i
    for i in "${!instances[@]}"; do
      local id name priv pub
      id=$(echo "${instances[$i]}"   | jq -r '.ID')
      name=$(echo "${instances[$i]}" | jq -r '.Name // "-"')
      priv=$(echo "${instances[$i]}" | jq -r '.PrivateIP // "-"')
      pub=$(echo "${instances[$i]}"  | jq -r '.PublicIP // "-"')
      printf "  ${BOLD}%-4s${RESET} %-22s %-16s %-16s %s\n" \
        "$((i+1))" "$id" "$priv" "$pub" "$name" >&2
    done
    echo "" >&2
    local choice
    read -rp "Select instance [1-${#instances[@]}]: " choice
    if [[ ! "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#instances[@]} )); then
      err "Invalid selection"; exit 1
    fi
    local selected="${instances[$((choice-1))]}"
    RESOLVED_ID=$(echo "$selected" | jq -r '.ID')
    RESOLVED_NAME=$(echo "$selected" | jq -r '.Name // ""')
  fi
}

# ── Resolve target ────────────────────────────────────────────────────────────
if [[ ${#POSITIONAL[@]} -ge 1 ]]; then
  target="${POSITIONAL[0]}"
  if [[ "$target" =~ ^i-[0-9a-f]{8}([0-9a-f]{9})?$ ]]; then
    resolve_by_id "$target"
  else
    resolve_by_name "$target"
  fi
else
  resolve_interactive
fi

# ── Connect or forward ────────────────────────────────────────────────────────
if [[ -n "$OPT_FORWARD" ]]; then
  IFS=':' read -ra fwd_parts <<< "$OPT_FORWARD"
  local_port="" remote_host="" remote_port=""

  if [[ ${#fwd_parts[@]} -eq 2 ]]; then
    local_port="${fwd_parts[0]}"
    remote_host="localhost"
    remote_port="${fwd_parts[1]}"
  elif [[ ${#fwd_parts[@]} -eq 3 ]]; then
    local_port="${fwd_parts[0]}"
    remote_host="${fwd_parts[1]}"
    remote_port="${fwd_parts[2]}"
  else
    err "Invalid -L spec '${OPT_FORWARD}'. Use local:remote_port or local:host:remote_port"
    exit 1
  fi

  display="${RESOLVED_NAME:-$RESOLVED_ID}"

  validate_port "$local_port"
  validate_port "$remote_port"
  [[ "$remote_host" != "localhost" && "$remote_host" != "127.0.0.1" ]] && validate_host "$remote_host"

  if [[ "$remote_host" == "localhost" || "$remote_host" == "127.0.0.1" ]]; then
    ok "Forwarding ${BOLD}localhost:${local_port}${RESET}${GREEN} → ${display}:${remote_port}${RESET}"
    info "Press Ctrl+C to stop"
    echo "" >&2
    aws_cmd ssm start-session \
      --target "$RESOLVED_ID" \
      --document-name AWS-StartPortForwardingSession \
      --parameters "{\"portNumber\":[\"${remote_port}\"],\"localPortNumber\":[\"${local_port}\"]}"
  else
    ok "Forwarding ${BOLD}localhost:${local_port}${RESET}${GREEN} → ${remote_host}:${remote_port}${RESET}${GREEN} via ${display}${RESET}"
    info "Press Ctrl+C to stop"
    echo "" >&2
    aws_cmd ssm start-session \
      --target "$RESOLVED_ID" \
      --document-name AWS-StartPortForwardingSessionToRemoteHost \
      --parameters "{\"host\":[\"${remote_host}\"],\"portNumber\":[\"${remote_port}\"],\"localPortNumber\":[\"${local_port}\"]}"
  fi
else
  if [[ -n "$RESOLVED_NAME" ]]; then
    ok "Connecting to ${BOLD}${RESOLVED_NAME}${RESET}${GREEN} (${RESOLVED_ID})${RESET} as ${BOLD}${SSM_USER}${RESET}"
  else
    ok "Connecting to ${BOLD}${RESOLVED_ID}${RESET} as ${BOLD}${SSM_USER}${RESET}"
  fi
  echo "" >&2

  login_cmd="command -v run-parts &>/dev/null && run-parts /etc/update-motd.d/; stty -ixon; exec bash"
  session_params="command=[\"sudo -i -u ${SSM_USER} bash --login -c '${login_cmd}'\"]"

  extra_args=()
  [[ -n "$OPT_REASON" ]] && extra_args+=(--reason "$OPT_REASON")

  aws_cmd ssm start-session \
    --target "$RESOLVED_ID" \
    --document-name AWS-StartInteractiveCommand \
    --parameters "$session_params" \
    "${extra_args[@]}"
fi
